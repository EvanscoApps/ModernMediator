<Window x:Class="ModernMediator.Sample.Wpf.Basic.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ModernMediator WPF Sample — MVVM + Mediator"
        Height="500" Width="700"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="12">

        <!-- ── Status Bar ── shows the last LoggingBehavior log entry -->
        <StatusBar DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding LastLogEntry}" />
            </StatusBarItem>
        </StatusBar>

        <!-- ── Search Panel ── dispatches FindAnimalByNameQuery via mediator -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <TextBlock Text="Search by Name" FontWeight="SemiBold" Margin="0,0,0,4" />
            <DockPanel>
                <!-- Search button dispatches the FindAnimalByNameQuery command -->
                <Button DockPanel.Dock="Right" Content="Search" Width="80" Margin="8,0,0,0"
                        Command="{Binding SearchCommand}" />
                <!-- TextBox bound to SearchName; typing triggers CanExecute re-evaluation -->
                <TextBox Text="{Binding SearchName, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center" Padding="4,2" />
            </DockPanel>
            <!-- Displays Result<Animal> outcome: success details or "not found" message -->
            <TextBlock Text="{Binding SearchResult}" Margin="0,4,0,0"
                       FontStyle="Italic" Foreground="DarkSlateGray" />
        </StackPanel>

        <!-- ── Reload button ── re-dispatches GetAnimalsQuery -->
        <Button DockPanel.Dock="Top" Content="Reload Animals" HorizontalAlignment="Left"
                Margin="0,0,0,8" Padding="12,4"
                Command="{Binding LoadCommand}" />

        <!-- ── Animal List ── bound to ObservableCollection<AnimalDisplayModel> -->
        <ListBox ItemsSource="{Binding Animals}" HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <!-- Each item shows Name, Type, Age, and type-specific Details -->
                    <Grid Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1" Text="{Binding Type}" />
                        <TextBlock Grid.Column="2" Text="{Binding AgeYears, StringFormat={}{0}y}" />
                        <TextBlock Grid.Column="3" Text="{Binding Details}" Foreground="Gray" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </DockPanel>
</Window>
